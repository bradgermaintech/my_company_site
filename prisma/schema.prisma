generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  manager
  bidder
  caller
  developer
}

enum PipelineStatus {
  Bid
  Response
  Intro
  Tech
  Culture
  Final
  Offer
  Rejected
}

enum ReleaseStatus {
  not_ready
  pending
  approved
  released
}

enum PaymentStatus {
  unbilled
  pending
  approved
  paid
}

enum InterviewStage {
  Intro
  Tech
  Culture
  Final
}

enum InterviewResult {
  scheduled
  passed
  failed
  reschedule
}

enum TaskStatus {
  todo
  in_progress
  review
  done
}

enum TaskPriority {
  low
  medium
  high
  urgent
}

enum ReleasePaymentStatus {
  pending
  approved
  paid
}

model User {
  id                    String          @id @default(cuid())
  name                  String          @default("Pipeline User")
  email                 String          @unique
  emailVerified         DateTime?
  image                 String?
  passwordHash          String?
  role                  UserRole        @default(bidder)
  avatar                String          @default("PO")
  active                Boolean         @default(true)
  lastSeenAt            DateTime?
  accounts              Account[]
  sessions              Session[]
  bidderApplications    Application[]   @relation("ApplicationBidder")
  callerApplications    Application[]   @relation("ApplicationCaller")
  developerApplications Application[]   @relation("ApplicationDeveloper")
  callerInterviews      Interview[]     @relation("InterviewCaller")
  developerInterviews   Interview[]     @relation("InterviewDeveloper")
  developerTasks        DeveloperTask[]
  approvedReleases      Release[]       @relation("ReleaseApprover")
  activities            Activity[]
  managerChatConversations ChatConversation[] @relation("ChatConversationManager")
  memberChatConversations ChatConversation[] @relation("ChatConversationMember")
  createdChatGroups     ChatGroup[]     @relation("ChatGroupCreator")
  chatGroupMemberships  ChatGroupMember[]
  sentChatGroupMessages ChatGroupMessage[] @relation("ChatGroupMessageSender")
  chatGroupReactions    ChatGroupReaction[] @relation("ChatGroupReactionUser")
  chatGroupTypingStates ChatGroupTyping[] @relation("ChatGroupTypingUser")
  sentChatMessages      ChatMessage[]    @relation("ChatMessageSender")
  chatReactions         ChatReaction[]    @relation("ChatReactionUser")
  chatTypingStates      ChatTyping[]      @relation("ChatTypingUser")
  resumeTailors         ResumeTailor[]
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@index([role, active])
  @@index([lastSeenAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Application {
  id             String         @id
  date           DateTime
  jobTitle       String
  company        String
  jdLink         String
  bidderId       String
  callerId       String
  developerId    String
  status         PipelineStatus
  resumeVersion  String
  releaseStatus  ReleaseStatus
  paymentStatus  PaymentStatus
  notes          String
  createdAt      DateTime
  updatedAt      DateTime
  bidder         User           @relation("ApplicationBidder", fields: [bidderId], references: [id], onDelete: Restrict)
  caller         User           @relation("ApplicationCaller", fields: [callerId], references: [id], onDelete: Restrict)
  developer      User           @relation("ApplicationDeveloper", fields: [developerId], references: [id], onDelete: Restrict)
  interviews     Interview[]
  resumeTailors  ResumeTailor[]
  developerTasks DeveloperTask[]
  releases       Release[]

  @@index([bidderId, status])
  @@index([callerId, status])
  @@index([developerId, status])
  @@index([status, updatedAt])
  @@index([company])
}

model Interview {
  id            String          @id
  applicationId String
  callerId      String
  developerId   String
  title         String
  stage         InterviewStage
  startTime     DateTime
  endTime       DateTime
  meetingLink   String
  notes         String
  result        InterviewResult
 
  googleEventId String?
  googleEventUrl String?
  googleSyncStatus String?
  googleSyncError String?
  googleSyncedAt DateTime?
  application   Application     @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  caller        User            @relation("InterviewCaller", fields: [callerId], references: [id], onDelete: Restrict)
  developer     User            @relation("InterviewDeveloper", fields: [developerId], references: [id], onDelete: Restrict)
  activities    Activity[]

  @@index([applicationId, startTime])
  @@index([callerId, startTime])
  @@index([developerId, startTime])
}

model ResumeTailor {
  id              String      @id
  userId          String
  applicationId   String?
  jdLink          String?
  baseResumeText  String
  jobDescription  String
  tailoredSummary String
  skillMatch      String
  coverLetter     String
  structuredResult Json?
  sourceFileName  String?
  sourceFileType  String?
  model           String      @default("gemini-2.5-flash")
  generatedAt     DateTime
  updatedAt       DateTime     @updatedAt
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  application     Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)

  @@index([userId, generatedAt])
  @@index([applicationId, generatedAt])
}

model DeveloperTask {
  id            String       @id
  developerId   String
  applicationId String
  title         String
  description   String
  status        TaskStatus
  priority      TaskPriority
  dueDate       DateTime
  developer     User         @relation(fields: [developerId], references: [id], onDelete: Restrict)
  application   Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([developerId, status])
  @@index([applicationId, status])
  @@index([dueDate])
}

model Release {
  id            String               @id
  applicationId String
  amount        Int
  status        ReleasePaymentStatus
  approvedBy    String
  paidAt        DateTime?
  application   Application          @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  approver      User                 @relation("ReleaseApprover", fields: [approvedBy], references: [id], onDelete: Restrict)

  @@index([applicationId, status])
  @@index([approvedBy, status])
}

model Activity {
  id        String   @id
  userId    String
 
  interviewId String?
 
  action    String
  target    String
  timestamp DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  interview Interview? @relation(fields: [interviewId], references: [id], onDelete: SetNull)

  @@index([userId, timestamp])
  @@index([interviewId, timestamp])
  @@index([timestamp])
}

model ChatConversation {
  id            String        @id
  managerId     String
  memberId      String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  lastMessageAt DateTime?
  manager       User          @relation("ChatConversationManager", fields: [managerId], references: [id], onDelete: Cascade)
  member        User          @relation("ChatConversationMember", fields: [memberId], references: [id], onDelete: Cascade)
  messages      ChatMessage[]
  typingStates  ChatTyping[]

  @@unique([managerId, memberId])
  @@index([managerId, lastMessageAt])
  @@index([memberId, lastMessageAt])
}

model ChatMessage {
  id             String           @id
  conversationId String
  senderId       String
  replyToId      String?
  content        String
  createdAt      DateTime         @default(now())
  editedAt       DateTime?
  readAt         DateTime?
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User             @relation("ChatMessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  replyTo        ChatMessage?      @relation("ChatMessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies        ChatMessage[]     @relation("ChatMessageReplies")
  reactions      ChatReaction[]

  @@index([conversationId, createdAt])
  @@index([senderId, createdAt])
  @@index([replyToId])
}

model ChatReaction {
  id        String      @id
  messageId String
  userId    String
  emoji     String
  createdAt DateTime    @default(now())
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User        @relation("ChatReactionUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([messageId])
  @@index([userId])
}

model ChatTyping {
  id             String           @id
  conversationId String
  userId         String
  updatedAt      DateTime         @updatedAt
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User             @relation("ChatTypingUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([conversationId, updatedAt])
}

model ChatGroup {
  id             String            @id
  name           String
  createdById    String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  lastMessageAt  DateTime?
  creator        User              @relation("ChatGroupCreator", fields: [createdById], references: [id], onDelete: Cascade)
  members        ChatGroupMember[]
  messages       ChatGroupMessage[]
  typingStates   ChatGroupTyping[]

  @@index([createdById, updatedAt])
  @@index([lastMessageAt])
}

model ChatGroupMember {
  id         String    @id
  groupId    String
  userId     String
  addedById  String
  joinedAt   DateTime  @default(now())
  lastReadAt DateTime?
  group      ChatGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId, joinedAt])
  @@index([groupId, lastReadAt])
}

model ChatGroupMessage {
  id         String             @id
  groupId     String
  senderId    String
  replyToId   String?
  content     String
  createdAt   DateTime          @default(now())
  editedAt    DateTime?
  group       ChatGroup         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sender      User              @relation("ChatGroupMessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  replyTo     ChatGroupMessage? @relation("ChatGroupMessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies     ChatGroupMessage[] @relation("ChatGroupMessageReplies")
  reactions   ChatGroupReaction[]

  @@index([groupId, createdAt])
  @@index([senderId, createdAt])
  @@index([replyToId])
}

model ChatGroupReaction {
  id        String           @id
  messageId String
  userId    String
  emoji     String
  createdAt DateTime         @default(now())
  message   ChatGroupMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User             @relation("ChatGroupReactionUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([messageId])
  @@index([userId])
}

model ChatGroupTyping {
  id        String    @id
  groupId   String
  userId    String
  updatedAt DateTime  @updatedAt
  group     ChatGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User      @relation("ChatGroupTypingUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([groupId, updatedAt])
}
